# ── AirSense Environment Variables ──────────────────────────
# Copy this file, rename to .env, fill in your values.
# NEVER push .env to GitHub.

# Admin secret for posting government advisories
ADMIN_SECRET=change_this_to_something_strong

# Gmail SMTP (for email alerts)
# Use Gmail App Password — NOT your actual Gmail password
# How to get App Password: Google Account → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_gmail_app_password
